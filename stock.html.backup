<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TradEdge — Stock Analysis</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<style>
:root{--bg-primary:#06080c;--bg-secondary:#0c1018;--bg-tertiary:#121820;--bg-card:#0f1520;--bg-hover:#141d2a;--border-dim:rgba(0,255,136,0.06);--border-low:rgba(0,255,136,0.1);--border-med:rgba(0,255,136,0.2);--border-hi:rgba(0,255,136,0.4);--accent:#00ff88;--accent-dim:rgba(0,255,136,0.15);--accent2:#00c8ff;--accent3:#8844ff;--red:#ff4455;--red-dim:rgba(255,68,85,0.12);--amber:#ffaa00;--text-primary:#e8e8e8;--text-secondary:#8899aa;--text-muted:#556677;--font-display:'Outfit',sans-serif;--font-mono:'JetBrains Mono',monospace}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg-primary);color:var(--text-primary);font-family:var(--font-display);min-height:100vh;overflow-x:hidden;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;text-rendering:optimizeLegibility}
body::after{content:'';position:fixed;top:0;left:0;right:0;bottom:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,255,136,0.008) 2px,rgba(0,255,136,0.008) 4px);pointer-events:none;z-index:9999}
body::before{content:'';position:fixed;top:0;left:0;right:0;bottom:0;background-image:linear-gradient(rgba(0,255,136,0.02) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,136,0.02) 1px,transparent 1px);background-size:48px 48px;pointer-events:none;z-index:0}
::-webkit-scrollbar{width:6px;height:6px}::-webkit-scrollbar-track{background:var(--bg-primary)}::-webkit-scrollbar-thumb{background:rgba(0,255,136,0.2);border-radius:3px}
#root{position:relative;z-index:1}
.card{background:var(--bg-card);border:1px solid var(--border-low);border-radius:8px;overflow:hidden}
.card:hover{border-color:var(--border-med)}
.badge{display:inline-block;padding:2px 8px;border-radius:3px;font-size:10px;font-weight:700;font-family:var(--font-mono);letter-spacing:.5px;white-space:nowrap}
.badge-pass{background:rgba(0,255,136,.12);color:#00ff88;border:1px solid rgba(0,255,136,.3)}
.badge-fair{background:rgba(0,200,255,.12);color:#00c8ff;border:1px solid rgba(0,200,255,.3)}
.badge-fail{background:rgba(255,68,85,.12);color:#ff4455;border:1px solid rgba(255,68,85,.3)}
.badge-poor{background:rgba(255,68,85,.1);color:#ff4455;border:1px solid rgba(255,68,85,.2)}
.badge-good{background:rgba(0,255,136,.1);color:#00ff88;border:1px solid rgba(0,255,136,.2)}
.badge-warn{background:rgba(255,170,0,.1);color:#ffaa00;border:1px solid rgba(255,170,0,.2)}
.nav{display:flex;align-items:center;gap:4px;padding:8px 20px;background:var(--bg-secondary);border-bottom:1px solid var(--border-dim);position:sticky;top:0;z-index:100}
.nav-brand{font-weight:900;font-size:16px;letter-spacing:2px;background:linear-gradient(135deg,#00ff88,#00c8ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-right:16px}
.nav-link{padding:5px 12px;font-size:11px;font-weight:600;color:var(--text-muted);text-decoration:none;border-radius:4px;font-family:var(--font-mono)}
.nav-link:hover{color:var(--text-primary);background:var(--bg-hover)}
.nav-link.active{color:var(--accent);background:var(--accent-dim)}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes logoPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.85;transform:scale(1.03)}}
.fade-in{animation:fadeIn .3s ease-out}
canvas{image-rendering:pixelated}
.live-indicator{display:inline-flex;align-items:center;gap:4px;font-size:9px;color:#00ff88;font-family:var(--font-mono)}
.live-dot{width:6px;height:6px;background:#00ff88;border-radius:50%;animation:blink 1.5s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
</style>
</head>
<body>
<div id="root"></div>

<script type="text/babel">
const {useState,useEffect,useMemo,useCallback,useRef,Fragment} = React;

// Get symbol from URL: stock.html?s=RELIANCE
const urlParams = new URLSearchParams(window.location.search);
const SYMBOL = (urlParams.get('s') || 'RELIANCE').toUpperCase();

// ═══════════════════════════════════════════════════════════════
// MOCK DATA (Replace with fetch in production)
// ═══════════════════════════════════════════════════════════════
const MOCK = {
  symbol: SYMBOL, name: "Loading...", sector: "Unknown", industry: "Unknown",
  price: 0, change_pct: 0, prev_close: 0,
  circuit: { band: "—", is_restricted: false },
  fundamentals: {},
  fund_holdings: {},
  oneil: { master_score: "?", eps_strength: 0, price_strength: 0, buyer_demand: "?", buyer_demand_score: 0, group_rank: 0, analysis_text: "Loading..." },
  guru_ratings: [],
  surveillance: { flags: [], red_flag_count: 0, assessment: "Loading", assessment_detail: "" },
  ownership: { promoter: [], mutual_funds: [], fii: [], public: [], dii: [] },
  quarterly_results: [],
  major_shareholders: [],
  management: [],
  price_history: [],
};

// ═══════════════════════════════════════════════════════════════
// HELPER COMPONENTS
// ═══════════════════════════════════════════════════════════════

const PctVal = ({val, str}) => {
  const s = str || (val != null ? `${val > 0 ? "+" : ""}${val}%` : "—");
  const isNeg = s.includes("-");
  const isPos = s.includes("+") && !isNeg;
  return <span style={{color:isPos?"#00ff88":isNeg?"#ff4455":"var(--text-secondary)",fontWeight:600,fontFamily:"var(--font-mono)",fontSize:12}}>{s}</span>;
};

const ScoreGrade = ({grade, size=40}) => {
  const colors = {A:"#00ff88",B:"#00c8ff",C:"#ffaa00",D:"#ff8800",E:"#ff4455"};
  return (
    <div style={{width:size,height:size,borderRadius:8,display:"flex",alignItems:"center",justifyContent:"center",
      background:colors[grade]||"#555",fontSize:size*0.5,fontWeight:900,color:"#000",fontFamily:"var(--font-display)"}}>
      {grade}
    </div>
  );
};

const ProgressBar = ({value, max=99, color="#00ff88", label}) => (
  <div>
    {label && <div style={{display:"flex",justifyContent:"space-between",fontSize:10,marginBottom:3}}>
      <span style={{color:"var(--text-secondary)"}}>{label}</span>
      <span style={{color,fontWeight:700,fontFamily:"var(--font-mono)"}}>{value}</span>
    </div>}
    <div style={{height:4,borderRadius:2,background:"rgba(255,255,255,0.05)"}}>
      <div style={{height:"100%",borderRadius:2,width:`${Math.min(value/max*100,100)}%`,background:color,transition:"width 0.5s"}}/>
    </div>
  </div>
);

const TrendArrow = ({curr, prev, inverse}) => {
  if (curr == null || prev == null) return null;
  const diff = curr - prev;
  if (Math.abs(diff) < 0.001) return <span style={{fontSize:7,color:"#556"}}>→</span>;
  const isUp = diff > 0;
  const isGood = inverse ? !isUp : isUp;
  return <span style={{fontSize:7,color:isGood?"#00ff88":"#ff4455"}}>{isUp?"▲":"▼"}</span>;
};

// ═══════════════════════════════════════════════════════════════
// TRADEDGE CUSTOM CHART — HLC Bars + 3 EMAs + Volume
// ═══════════════════════════════════════════════════════════════

function calcEMA(closes, period) {
  const k = 2 / (period + 1), ema = [closes[0]];
  for (let i = 1; i < closes.length; i++) ema.push(closes[i] * k + ema[i - 1] * (1 - k));
  return ema;
}
function fmtVol(v) { return v >= 1e7 ? (v/1e7).toFixed(2)+" Cr" : v >= 1e5 ? (v/1e5).toFixed(1)+" L" : v >= 1e3 ? (v/1e3).toFixed(0)+"K" : v+""; }

const TEChart = ({symbol, prices}) => {
  const canvasRef = useRef(null);
  const [viewStart, setViewStart] = useState(null);
  const [viewCount, setViewCount] = useState(120);
  const [crosshair, setCrosshair] = useState(null);
  const [isDrag, setIsDrag] = useState(false);
  const [dragX, setDragX] = useState(null);
  const [showEMA, setShowEMA] = useState({e20:true,e50:true,e200:true});
  const [hoverBar, setHoverBar] = useState(null);

  const priceData = useMemo(() => prices || [], [prices]);
  const start = viewStart ?? Math.max(0, priceData.length - viewCount);
  const visible = priceData.slice(start, start + viewCount);
  const closes = useMemo(() => priceData.map(d => d.c), [priceData]);
  const ema20 = useMemo(() => closes.length >= 20 ? calcEMA(closes, 20) : [], [closes]);
  const ema50 = useMemo(() => closes.length >= 50 ? calcEMA(closes, 50) : [], [closes]);
  const ema200 = useMemo(() => closes.length >= 200 ? calcEMA(closes, 200) : [], [closes]);

  const draw = useCallback(() => {
    const canvas = canvasRef.current;
    if (!canvas || !visible.length) return;
    const ctx = canvas.getContext("2d");
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.parentElement.getBoundingClientRect();
    const W = rect.width, H = 480;
    canvas.width = W * dpr; canvas.height = H * dpr;
    canvas.style.width = W + "px"; canvas.style.height = H + "px";
    ctx.scale(dpr, dpr);

    const padL = 62, padR = 10, padT = 10, padB = 22;
    const volH = 72, chartH = H - padT - padB - volH - 8;
    const chartW = W - padL - padR, barW = chartW / viewCount;

    let allH = visible.map(d => d.h), allL = visible.map(d => d.l);
    for (let i = 0; i < visible.length; i++) {
      const gi = start + i;
      if (showEMA.e20 && gi < ema20.length) { allH.push(ema20[gi]); allL.push(ema20[gi]); }
      if (showEMA.e50 && gi < ema50.length) { allH.push(ema50[gi]); allL.push(ema50[gi]); }
      if (showEMA.e200 && gi < ema200.length) { allH.push(ema200[gi]); allL.push(ema200[gi]); }
    }
    const pMax = Math.max(...allH) * 1.005, pMin = Math.min(...allL) * 0.995, pRng = pMax - pMin || 1;
    const toY = (p) => padT + (1 - (p - pMin) / pRng) * chartH;
    const toX = (i) => padL + i * barW + barW / 2;
    const maxVol = Math.max(...visible.map(d => d.v)) || 1;
    const volTop = padT + chartH + 8;
    const toVolY = (v) => volTop + volH - (v / maxVol) * volH;

    ctx.fillStyle = "#06080c"; ctx.fillRect(0, 0, W, H);

    ctx.strokeStyle = "rgba(0,255,136,0.04)"; ctx.lineWidth = 0.5;
    for (let i = 0; i <= 6; i++) {
      const p = pMin + pRng * i / 6, y = toY(p);
      ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(W - padR, y); ctx.stroke();
      ctx.fillStyle = "#334"; ctx.font = "10px 'JetBrains Mono',monospace"; ctx.textAlign = "right";
      ctx.fillText(p.toFixed(1), padL - 6, y + 3);
    }

    ctx.fillStyle = "#334"; ctx.font = "9px 'JetBrains Mono',monospace"; ctx.textAlign = "center";
    const dStep = Math.max(1, Math.floor(viewCount / 8));
    for (let i = 0; i < visible.length; i += dStep) {
      const x = toX(i), dt = visible[i].date || "";
      if (dt) { const p = dt.split("-"); ctx.fillText(p[2]+"/"+p[1], x, H - 4); }
    }

    for (let i = 0; i < visible.length; i++) {
      const b = visible[i], x = toX(i), bull = b.c >= b.o;
      ctx.fillStyle = bull ? "rgba(0,204,102,0.25)" : "rgba(238,51,68,0.25)";
      ctx.fillRect(x - barW * 0.35, toVolY(b.v), barW * 0.7, volTop + volH - toVolY(b.v));
    }

    const drawEMA = (ed, col) => {
      ctx.strokeStyle = col; ctx.lineWidth = 1.2; ctx.beginPath(); let s = false;
      for (let i = 0; i < visible.length; i++) {
        const gi = start + i; if (gi >= ed.length) break;
        const x = toX(i), y = toY(ed[gi]);
        if (!s) { ctx.moveTo(x, y); s = true; } else ctx.lineTo(x, y);
      } ctx.stroke();
    };
    if (showEMA.e200 && ema200.length) drawEMA(ema200, "#ff6644");
    if (showEMA.e50 && ema50.length) drawEMA(ema50, "#ffaa00");
    if (showEMA.e20 && ema20.length) drawEMA(ema20, "#00bbff");

    for (let i = 0; i < visible.length; i++) {
      const b = visible[i], x = toX(i), bull = b.c >= b.o;
      const col = bull ? "#00cc66" : "#ee3344";
      ctx.strokeStyle = col; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(x, toY(b.h)); ctx.lineTo(x, toY(b.l)); ctx.stroke();
      ctx.lineWidth = 1.5;
      ctx.beginPath(); ctx.moveTo(x, toY(b.c)); ctx.lineTo(x + barW * 0.35, toY(b.c)); ctx.stroke();
    }

    if (crosshair) {
      const {x: mx, y: my} = crosshair;
      if (mx >= padL && mx <= W - padR) {
        ctx.strokeStyle = "rgba(0,255,136,0.2)"; ctx.lineWidth = 0.5; ctx.setLineDash([3,3]);
        ctx.beginPath(); ctx.moveTo(mx, padT); ctx.lineTo(mx, H - padB); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(padL, my); ctx.lineTo(W - padR, my); ctx.stroke();
        ctx.setLineDash([]);
        if (my >= padT && my <= padT + chartH) {
          const pr = pMax - ((my - padT) / chartH) * pRng;
          ctx.fillStyle = "#0a1520"; ctx.fillRect(0, my - 9, padL - 2, 18);
          ctx.strokeStyle = "#00ff88"; ctx.lineWidth = 0.5; ctx.strokeRect(0, my - 9, padL - 2, 18);
          ctx.fillStyle = "#00ff88"; ctx.font = "bold 9px 'JetBrains Mono',monospace"; ctx.textAlign = "right";
          ctx.fillText(pr.toFixed(2), padL - 6, my + 3);
        }
      }
    }

    ctx.fillStyle = "#ddd"; ctx.font = "bold 13px 'Outfit',sans-serif"; ctx.textAlign = "left";
    ctx.fillText("NSE:" + symbol, padL + 4, padT + 16);

    const hb = hoverBar || visible[visible.length - 1];
    if (hb) {
      const iy = padT + 32; const bc = hb.c >= hb.o ? "#00cc66" : "#ee3344";
      ctx.font = "11px 'JetBrains Mono',monospace";
      ctx.fillStyle = "#667"; ctx.fillText("O ", padL + 4, iy);
      ctx.fillStyle = bc; ctx.fillText(hb.o?.toFixed(2), padL + 20, iy);
      ctx.fillStyle = "#667"; ctx.fillText("H ", padL + 88, iy);
      ctx.fillStyle = bc; ctx.fillText(hb.h?.toFixed(2), padL + 104, iy);
      ctx.fillStyle = "#667"; ctx.fillText("L ", padL + 172, iy);
      ctx.fillStyle = bc; ctx.fillText(hb.l?.toFixed(2), padL + 186, iy);
      ctx.fillStyle = "#667"; ctx.fillText("C ", padL + 254, iy);
      ctx.fillStyle = bc; ctx.fillText(hb.c?.toFixed(2), padL + 268, iy);
      ctx.fillStyle = "#667"; ctx.fillText("V ", padL + 340, iy);
      ctx.fillStyle = "#aaa"; ctx.fillText(fmtVol(hb.v || 0), padL + 354, iy);
    }

    const ey = padT + 48;
    if (showEMA.e20 && ema20.length) { ctx.fillStyle = "#00bbff"; ctx.font = "10px 'JetBrains Mono',monospace"; ctx.fillText("EMA20: " + (ema20[start + visible.length - 1]?.toFixed(2)||"—"), padL + 4, ey); }
    if (showEMA.e50 && ema50.length) { ctx.fillStyle = "#ffaa00"; ctx.fillText("EMA50: " + (ema50[start + visible.length - 1]?.toFixed(2)||"—"), padL + 140, ey); }
    if (showEMA.e200 && ema200.length) { ctx.fillStyle = "#ff6644"; ctx.fillText("EMA200: " + (ema200[start + visible.length - 1]?.toFixed(2)||"—"), padL + 280, ey); }

    ctx.strokeStyle = "rgba(0,255,136,0.06)"; ctx.lineWidth = 0.5;
    ctx.beginPath(); ctx.moveTo(padL, volTop - 4); ctx.lineTo(W - padR, volTop - 4); ctx.stroke();
  }, [visible, viewCount, start, crosshair, showEMA, hoverBar, symbol, ema20, ema50, ema200, priceData]);

  useEffect(() => { draw(); }, [draw]);
  useEffect(() => { const h = () => draw(); window.addEventListener("resize", h); return () => window.removeEventListener("resize", h); }, [draw]);

  const handleMouseMove = (e) => {
    const rect = canvasRef.current?.getBoundingClientRect(); if (!rect) return;
    const mx = e.clientX - rect.left, my = e.clientY - rect.top;
    setCrosshair({x: mx, y: my});
    const padL = 62, chartW = rect.width - padL - 10, bw = chartW / viewCount;
    const idx = Math.round((mx - padL) / bw - 0.5);
    setHoverBar(idx >= 0 && idx < visible.length ? visible[idx] : null);
    if (isDrag && dragX != null) {
      const delta = e.clientX - dragX, bDelta = Math.round(delta / bw);
      if (Math.abs(bDelta) >= 1) {
        setViewStart(pv => { const s = (pv ?? Math.max(0, priceData.length - viewCount)) - bDelta; return Math.max(0, Math.min(priceData.length - viewCount, s)); });
        setDragX(e.clientX);
      }
    }
  };

  const handleWheel = (e) => {
    e.preventDefault();
    setViewCount(pv => { const n = pv + (e.deltaY > 0 ? 1 : -1) * Math.max(3, Math.floor(pv * 0.1)); return Math.max(20, Math.min(priceData.length, n)); });
  };

  if (!priceData.length) {
    return (
      <div style={{background:"var(--bg-card)",border:"1px solid var(--border-low)",borderRadius:8,padding:40,textAlign:"center"}}>
        <div style={{color:"var(--text-muted)",fontSize:12,marginBottom:8}}>No price data available for chart</div>
        <div style={{display:"flex",gap:6,justifyContent:"center"}}>
          <button onClick={() => window.open(`https://in.tradingview.com/chart/8RFOgQZr/?symbol=NSE%3A${symbol}&interval=D`, 'tradedge_tv')}
            style={{padding:"6px 14px",borderRadius:4,fontSize:11,fontWeight:700,fontFamily:"var(--font-mono)",cursor:"pointer",border:"1px solid rgba(0,200,255,0.3)",background:"rgba(0,200,255,0.08)",color:"#00c8ff"}}>
            ⭐ Open in TradingView Pro
          </button>
        </div>
      </div>
    );
  }

  return (
    <div style={{background:"var(--bg-card)",borderRadius:10,border:"1px solid var(--border-low)",overflow:"hidden"}}>
      <div style={{display:"flex",alignItems:"center",gap:6,padding:"6px 12px",background:"var(--bg-secondary)",borderBottom:"1px solid var(--border-dim)",flexWrap:"wrap"}}>
        <a href="index.html" style={{display:"flex",alignItems:"center"}}><img src="assets/logo.jpeg" alt="TradEdge" style={{height:100,marginRight:16,animation:"logoPulse 3s ease-in-out infinite"}}/></a>
        <span style={{fontSize:9,color:"var(--text-muted)",fontFamily:"var(--font-mono)"}}>HLC + Volume</span>
        {[{k:"e20",l:"EMA 20",c:"#00bbff"},{k:"e50",l:"EMA 50",c:"#ffaa00"},{k:"e200",l:"EMA 200",c:"#ff6644"}].map(em => (
          <button key={em.k} onClick={() => setShowEMA(p => ({...p,[em.k]:!p[em.k]}))}
            style={{padding:"2px 8px",borderRadius:3,fontSize:9,fontWeight:700,fontFamily:"var(--font-mono)",cursor:"pointer",
              border:`1px solid ${showEMA[em.k]?em.c+"55":"var(--border-dim)"}`,
              background:showEMA[em.k]?em.c+"15":"transparent",color:showEMA[em.k]?em.c:"var(--text-muted)"}}>
            {em.l}
          </button>
        ))}
        <div style={{marginLeft:"auto",display:"flex",gap:4}}>
          <button onClick={() => window.open(`https://in.tradingview.com/chart/8RFOgQZr/?symbol=NSE%3A${symbol}&interval=D`, 'tradedge_tv')}
            style={{padding:"2px 8px",borderRadius:3,fontSize:9,fontWeight:700,fontFamily:"var(--font-mono)",cursor:"pointer",border:"1px solid rgba(0,200,255,0.2)",background:"transparent",color:"#00c8ff"}}>
            ⭐ TV Pro
          </button>
          <button onClick={() => window.open(`https://zone.definedge.com/chart/NSE/${symbol}/pf`, '_blank')}
            style={{padding:"2px 8px",borderRadius:3,fontSize:9,fontWeight:700,fontFamily:"var(--font-mono)",cursor:"pointer",border:"1px solid rgba(136,68,255,0.2)",background:"transparent",color:"#8844ff"}}>
            🔷 P&F
          </button>
          <button onClick={() => window.open(`https://zone.definedge.com/chart/NSE/${symbol}/renko`, '_blank')}
            style={{padding:"2px 8px",borderRadius:3,fontSize:9,fontWeight:700,fontFamily:"var(--font-mono)",cursor:"pointer",border:"1px solid rgba(136,68,255,0.2)",background:"transparent",color:"#8844ff"}}>
            🔷 Renko
          </button>
        </div>
      </div>
      <div style={{cursor:isDrag?"grabbing":"crosshair"}}>
        <canvas ref={canvasRef}
          onMouseMove={handleMouseMove}
          onMouseLeave={() => { setCrosshair(null); setHoverBar(null); setIsDrag(false); }}
          onMouseDown={(e) => { setIsDrag(true); setDragX(e.clientX); }}
          onMouseUp={() => { setIsDrag(false); setDragX(null); }}
          onWheel={handleWheel}
          style={{display:"block",width:"100%"}}/>
      </div>
      <div style={{display:"flex",justifyContent:"space-between",padding:"3px 12px",background:"var(--bg-secondary)",
        borderTop:"1px solid var(--border-dim)",fontSize:8,fontFamily:"var(--font-mono)",color:"var(--text-muted)"}}>
        <span>Bars: {viewCount} | Visible: {visible.length} | Total: {priceData.length} | Scroll: Zoom | Drag: Pan</span>
        <span style={{color:"var(--accent)"}}>◈ TradEdge — Zero External Dependencies</span>
      </div>
    </div>
  );
};

// ═══════════════════════════════════════════════════════════════
// OWNERSHIP PATTERN BAR
// ═══════════════════════════════════════════════════════════════

const OwnershipBar = ({ownership}) => {
  const latest = {
    promoter: ownership.promoter[0]?.pct || 0,
    mf: ownership.mutual_funds[0]?.pct || 0,
    fii: ownership.fii[0]?.pct || 0,
    public: ownership.public[0]?.pct || 0,
    dii: ownership.dii[0]?.pct || 0,
  };
  const segments = [
    {label:"Promoter",pct:latest.promoter,color:"#8844ff"},
    {label:"FII",pct:latest.fii,color:"#00c8ff"},
    {label:"MF",pct:latest.mf,color:"#ff8800"},
    {label:"Public",pct:latest.public,color:"#00ff88"},
    {label:"DII",pct:latest.dii,color:"#ff4455"},
  ];
  return (
    <div>
      <div style={{display:"flex",height:32,borderRadius:4,overflow:"hidden",marginBottom:8}}>
        {segments.map((s,i) => s.pct > 0 && (
          <div key={i} style={{width:`${s.pct}%`,background:s.color,display:"flex",alignItems:"center",
            justifyContent:"center",fontSize:9,fontWeight:700,color:"#000",fontFamily:"var(--font-mono)"}}>{s.pct > 5 ? `${s.pct}%` : ""}</div>
        ))}
      </div>
      <div style={{display:"flex",gap:12,flexWrap:"wrap"}}>
        {segments.map((s,i) => (
          <div key={i} style={{display:"flex",alignItems:"center",gap:4,fontSize:10}}>
            <div style={{width:8,height:8,borderRadius:2,background:s.color}}/>
            <span style={{color:"var(--text-secondary)"}}>{s.label}</span>
            <span style={{color:"var(--text-primary)",fontWeight:600,fontFamily:"var(--font-mono)"}}>{s.pct}%</span>
          </div>
        ))}
      </div>
    </div>
  );
};

// ═══════════════════════════════════════════════════════════════
// MAIN STOCK PAGE
// ═══════════════════════════════════════════════════════════════

const StockPage = () => {
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(true);
  const [livePrice, setLivePrice] = useState(null);
  const [screenerData, setScreenerData] = useState(null);
  const [screenerLoading, setScreenerLoading] = useState(true);

  const FUND_PROXIES = [
    u => `https://api.allorigins.win/raw?url=${encodeURIComponent(u)}`,
    u => `https://corsproxy.io/?${encodeURIComponent(u)}`,
    u => `https://api.codetabs.com/v1/proxy?quest=${encodeURIComponent(u)}`,
  ];

  // ═══ LIVE PRICE FETCH (Intraday) ═══
  const fetchLivePrice = async (symbol) => {
    const wUrl = localStorage.getItem('zd_worker_url');
    if (!wUrl) return null;
    
    try {
      const res = await fetch(wUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Kite-Action': 'yahoo-proxy' },
        body: JSON.stringify({ ticker: `${symbol}.NS`, range: '1d', interval: '1m' })
      });
      
      if (!res.ok) return null;
      
      const data = await res.json();
      const result = data?.chart?.result?.[0];
      if (!result) return null;
      
      const meta = result.meta || {};
      const quotes = result.indicators?.quote?.[0] || {};
      const closes = quotes.close || [];
      
      // Priority: regularMarketPrice > latest 1m candle > previousClose
      let price = meta.regularMarketPrice;
      if (!price || price <= 0) {
        for (let i = closes.length - 1; i >= 0; i--) {
          if (closes[i] && closes[i] > 0) { price = closes[i]; break; }
        }
      }
      if (!price || price <= 0) price = meta.previousClose;
      
      const prevClose = meta.chartPreviousClose || meta.previousClose || 0;
      const change = prevClose > 0 ? ((price - prevClose) / prevClose * 100) : 0;
      
      console.log('[LIVE PRICE]', symbol, '₹' + price?.toFixed(2), change.toFixed(2) + '%');
      
      return { price, change_pct: +change.toFixed(2), prev_close: prevClose };
    } catch (e) {
      console.warn('[LIVE PRICE] Failed:', e.message);
      return null;
    }
  };

  async function fundFetchScreener(symbol) {
    const sym = symbol.replace('.NS','').replace('.BO','').toUpperCase();
    const workerUrl = localStorage.getItem('zd_worker_url') || '';
    if (workerUrl) {
      try {
        const r = await fetch(workerUrl, {
          method: 'GET',
          headers: { 'X-Kite-Action': 'screener', 'X-Screener-Symbol': sym },
          signal: AbortSignal.timeout(15000),
        });
        if (r.ok) {
          const data = await r.json();
          if (data.quarters?.length) return data;
        }
      } catch(e) { console.warn('[FUND] Worker fetch failed for', sym, e.message); }
    }
    return null;
  }

  async function fetchShareholding(symbol) {
    const sym = symbol.replace('.NS','').replace('.BO','').toUpperCase();
    const targetUrl = `https://www.screener.in/company/${sym}/consolidated/`;
    
    for (const proxyFn of FUND_PROXIES) {
      try {
        const url = proxyFn(targetUrl);
        const r = await fetch(url, { signal: AbortSignal.timeout(12000) });
        if (!r.ok) continue;
        const html = await r.text();
        
        const result = { promoter: [], fii: [], dii: [], public: [], mutual_funds: [], no_of_funds: null };
        const tables = html.match(/<table[^>]*>[\s\S]*?<\/table>/gi) || [];
        
        for (const table of tables) {
          const tableText = table.replace(/<[^>]+>/g, ' ').toLowerCase();
          if (!tableText.includes('promoter') || !tableText.includes('public')) continue;
          
          const rows = table.match(/<tr[\s\S]*?<\/tr>/gi) || [];
          const quarters = [];
          const firstRow = rows[0] || "";
          const headers = firstRow.match(/<t[hd][^>]*>([\s\S]*?)<\/t[hd]>/gi) || [];
          headers.forEach(th => {
            const txt = th.replace(/<[^>]+>/g, '').trim();
            if (txt.match(/\w{3}\s*\d{2,4}/)) quarters.push(txt);
          });
          
          if (!quarters.length) continue;
          
          for (const row of rows.slice(1)) {
            const cells = row.match(/<td[^>]*>([\s\S]*?)<\/td>/gi) || [];
            const values = cells.map(td => td.replace(/<[^>]+>/g, '').trim());
            if (values.length < 2) continue;
            
            const label = values[0]?.toLowerCase() || "";
            const nums = values.slice(1).map(v => parseFloat(v.replace(/,/g, '')) || 0);
            const buildQtrData = () => quarters.slice(0, nums.length).map((q, i) => ({ qtr: q, pct: nums[i] || 0 }));
            
            if (label.includes("promoter") && !label.includes("pledge")) result.promoter = buildQtrData();
            else if (label.includes("fii") || label.includes("foreign inst")) result.fii = buildQtrData();
            else if (label.includes("dii") || label.includes("domestic inst")) result.dii = buildQtrData();
            else if (label.includes("public") || label.includes("others")) result.public = buildQtrData();
            else if (label.includes("mutual fund")) result.mutual_funds = buildQtrData();
          }
          
          if (result.promoter.length > 0) break;
        }
        
        if (result.promoter.length > 0) return result;
      } catch(e) { continue; }
    }
    return null;
  }

  // ═══ LOAD STOCK DATA ═══
  useEffect(() => {
    async function loadStock() {
      try {
        const res = await fetch(`./data/stock_details/${SYMBOL}.json?t=${Date.now()}`);
        if (res.ok) {
          const json = await res.json();
          console.log("[STOCK] Loaded from stock_details/", SYMBOL);
          setData(json);
          setLoading(false);
          
          // Fetch live price
          const live = await fetchLivePrice(SYMBOL);
          if (live?.price > 0) {
            setLivePrice(live);
            setData(prev => ({ ...prev, price: live.price, change_pct: live.change_pct }));
          }
          return;
        }
      } catch (e) { console.warn("[STOCK] stock_details fetch failed:", e.message); }

      try {
        const res = await fetch("./data/scanner_results.json?t=" + Date.now());
        if (res.ok) {
          const json = await res.json();
          const stock = (json.stocks || []).find(s => s.symbol === SYMBOL);
          if (stock) {
            setData({
              ...stock,
              oneil: stock.oneil || {master_score:"?",eps_strength:0,price_strength:0,buyer_demand:"?",buyer_demand_score:0,group_rank:0,analysis_text:""},
              guru_ratings: stock.guru_ratings || [],
              surveillance: stock.surveillance || {flags:[],red_flag_count:0,assessment:"",assessment_detail:""},
              ownership: stock.ownership || {promoter:[],mutual_funds:[],fii:[],public:[],dii:[]},
              quarterly_results: stock.quarterly_results || [],
              major_shareholders: stock.major_shareholders || [],
              management: stock.management || [],
              price_history: stock.price_history || [],
            });
            setLoading(false);
            
            const live = await fetchLivePrice(SYMBOL);
            if (live?.price > 0) {
              setLivePrice(live);
              setData(prev => ({ ...prev, price: live.price, change_pct: live.change_pct }));
            }
            return;
          }
        }
      } catch (e) {}

      console.warn("Using mock data for", SYMBOL);
      setData(MOCK);
      setLoading(false);
      
      const live = await fetchLivePrice(SYMBOL);
      if (live?.price > 0) {
        setLivePrice(live);
        setData(prev => ({ ...prev, price: live.price, change_pct: live.change_pct }));
      }
    }
    loadStock();
  }, []);

  // Fetch screener.in data
  useEffect(() => {
    if (!SYMBOL) return;
    setScreenerLoading(true);
    
    fundFetchScreener(SYMBOL).then(sData => {
      if (sData) {
        setScreenerData(sData);
        if (sData.shareholding) {
          const sh = sData.shareholding;
          setData(prev => {
            if (!prev) return prev;
            const updated = {...prev};
            if (sh.promoter?.length || sh.fii?.length) {
              const qtrs = sh.quarters || [];
              updated.ownership = {
                promoter: qtrs.map((q, i) => ({ qtr: q, pct: sh.promoter?.[i] || 0 })),
                fii: qtrs.map((q, i) => ({ qtr: q, pct: sh.fii?.[i] || 0 })),
                dii: qtrs.map((q, i) => ({ qtr: q, pct: sh.dii?.[i] || 0 })),
                public: qtrs.map((q, i) => ({ qtr: q, pct: sh.public?.[i] || 0 })),
                mutual_funds: [],
              };
            }
            return updated;
          });
        }
      }
      setScreenerLoading(false);
    }).catch(() => setScreenerLoading(false));

    fetchShareholding(SYMBOL).then(shData => {
      if (shData?.promoter?.length) {
        setData(prev => {
          if (!prev) return prev;
          return { ...prev, ownership: { ...shData } };
        });
      }
    }).catch(() => {});
  }, []);

  // Auto-refresh live price every 60 seconds
  useEffect(() => {
    const interval = setInterval(async () => {
      const live = await fetchLivePrice(SYMBOL);
      if (live?.price > 0) {
        setLivePrice(live);
        setData(prev => prev ? { ...prev, price: live.price, change_pct: live.change_pct } : prev);
      }
    }, 60000);
    return () => clearInterval(interval);
  }, []);

  if (loading) {
    return (
      <div>
        <nav className="nav">
          <a href="index.html" style={{display:"flex",alignItems:"center"}}><img src="assets/logo.jpeg" alt="TradEdge" style={{height:100,marginRight:16}}/></a>
          <a href="scanner.html" className="nav-link">Scanner</a>
          <a href="sectors.html" className="nav-link">Sectors</a>
          <a href="rrg.html" className="nav-link">RRG</a>
          <a href="matrix.html" className="nav-link">Matrix</a>
          <a href="mps.html" className="nav-link">MPS</a>
          <a href="index.html" className="nav-link">Journal</a>
          <a href="watchlist.html" className="nav-link">Watchlist</a>
        </nav>
        <div style={{display:"flex",justifyContent:"center",alignItems:"center",height:"60vh",flexDirection:"column",gap:12}}>
          <div style={{width:40,height:40,border:"3px solid var(--border-low)",borderTop:"3px solid var(--accent)",
            borderRadius:"50%",animation:"spin 0.8s linear infinite"}}/>
          <div style={{color:"var(--text-muted)",fontSize:12,fontFamily:"var(--font-mono)"}}>Loading {SYMBOL}...</div>
          <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
        </div>
      </div>
    );
  }

  if (!data) return <div style={{padding:40,textAlign:"center",color:"var(--text-muted)"}}>Stock not found</div>;

  const d = data;
  const si = screenerData?.info || {};
  const f = { ...d.fundamentals, market_cap_cr: d.fundamentals?.market_cap_cr || si.mcapCr, pe_ratio: d.fundamentals?.pe_ratio || si.pe, roe: d.fundamentals?.roe || si.roe };
  const o = d.oneil || {};
  
  if (!d.guru_ratings) d.guru_ratings = [];
  if (!d.surveillance) d.surveillance = {flags:[], red_flag_count:0, assessment:""};
  if (!d.surveillance.flags) d.surveillance.flags = [];
  if (!d.ownership) d.ownership = {promoter:[],mutual_funds:[],fii:[],public:[],dii:[]};
  if (!d.price_history) d.price_history = [];

  return (
    <div>
      <nav className="nav">
        <a href="index.html" style={{display:"flex",alignItems:"center"}}><img src="assets/logo.jpeg" alt="TradEdge" style={{height:100,marginRight:16}}/></a>
        <a href="scanner.html" className="nav-link">Scanner</a>
        <a href="sectors.html" className="nav-link">Sectors</a>
        <a href="rrg.html" className="nav-link">RRG</a>
        <a href="matrix.html" className="nav-link">Matrix</a>
        <a href="mps.html" className="nav-link">MPS</a>
        <a href="index.html" className="nav-link">Journal</a>
        <a href="watchlist.html" className="nav-link">Watchlist</a>
        <a href="#" className="nav-link active">Stock</a>
        <a href="javascript:history.back()" className="nav-link" style={{marginLeft:"auto",color:"#00ff88"}}>← Back</a>
      </nav>

      <div style={{maxWidth:1300,margin:"0 auto",padding:"16px 20px"}}>
        {/* HEADER */}
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:16,flexWrap:"wrap",gap:12}} className="fade-in">
          <div>
            <div style={{display:"flex",alignItems:"center",gap:10}}>
              <h1 style={{fontSize:28,fontWeight:900,color:"#fff"}}>{d.symbol}</h1>
              <span style={{fontSize:13,color:"var(--text-secondary)"}}>{d.name}</span>
            </div>
            <div style={{display:"flex",gap:6,marginTop:4,flexWrap:"wrap"}}>
              <span className="badge badge-fair">{d.sector || 'Unknown'}</span>
              {d.industry && <span className="badge" style={{background:"rgba(136,68,255,0.1)",color:"#8844ff",border:"1px solid rgba(136,68,255,0.2)"}}>{d.industry}</span>}
              {d.circuit?.band && <span className={`badge ${d.circuit.is_restricted?"badge-fail":"badge-pass"}`}>Circuit: {d.circuit.band}</span>}
            </div>
          </div>
          <div style={{textAlign:"right"}}>
            <div style={{display:"flex",alignItems:"center",gap:8,justifyContent:"flex-end"}}>
              <span style={{fontSize:32,fontWeight:800,color:"#fff",fontFamily:"var(--font-mono)"}}>₹{(d.price || 0).toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2})}</span>
              {livePrice && <span className="live-indicator"><span className="live-dot"></span>LIVE</span>}
            </div>
            <PctVal val={d.change_pct}/>
          </div>
        </div>

        {/* CHART */}
        <div style={{marginBottom:16}} className="fade-in">
          <TEChart symbol={d.symbol} prices={d.price_history || []}/>
        </div>

        {/* FUNDAMENTALS */}
        <div className="card fade-in" style={{marginBottom:16}}>
          <div style={{padding:"10px 16px",borderBottom:"1px solid var(--border-dim)",fontSize:11,fontWeight:700,fontFamily:"var(--font-mono)",color:"var(--text-muted)",letterSpacing:1}}>FUNDAMENTALS</div>
          <div style={{padding:16,display:"grid",gridTemplateColumns:"repeat(5,1fr)",gap:1,background:"var(--border-dim)"}}>
            {[
              ["Market Cap", f.market_cap_cr ? `INR ${f.market_cap_cr.toLocaleString()} Cr` : "N/A"],
              ["P/E", f.pe_ratio ?? "N/A"],
              ["ROE", f.roe ? `${f.roe}%` : "N/A"],
              ["Book Value", f.book_value ?? "N/A"],
              ["EPS", f.eps ?? "N/A"],
              ["Dividend Yield", f.dividend_yield ? `${f.dividend_yield}%` : "N/A"],
              ["ROCE", f.roce ? `${f.roce}%` : "N/A"],
              ["Debt/Equity", f.debt_to_equity ?? "N/A"],
              ["Beta", f.beta ?? "N/A"],
              ["Rev Growth", f.revenue_growth ? `${f.revenue_growth}%` : "N/A"],
            ].map(([label, val], i) => (
              <div key={i} style={{background:"var(--bg-card)",padding:"8px 12px"}}>
                <div style={{fontSize:9,color:"var(--text-muted)",fontFamily:"var(--font-mono)",marginBottom:2}}>{label}</div>
                <div style={{fontSize:13,fontWeight:600,color:"var(--text-primary)",fontFamily:"var(--font-mono)"}}>{val}</div>
              </div>
            ))}
          </div>
        </div>

        {/* O'NEIL + GURU */}
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16,marginBottom:16}}>
          <div className="card fade-in">
            <div style={{padding:"10px 16px",borderBottom:"1px solid var(--border-dim)",fontSize:11,fontWeight:700,fontFamily:"var(--font-mono)",color:"var(--text-muted)",letterSpacing:1}}>O'NEIL MASTER SCORE</div>
            <div style={{padding:16}}>
              <div style={{display:"flex",gap:16,alignItems:"flex-start",marginBottom:16}}>
                <ScoreGrade grade={o.master_score} size={52}/>
                <div style={{flex:1}}>
                  <div style={{fontSize:13,fontWeight:700,marginBottom:4}}>Master Score {o.master_score}:</div>
                  <div style={{fontSize:11,color:"var(--text-secondary)",lineHeight:1.6}}>{(o.analysis_text || '').substring(0, 300)}...</div>
                </div>
              </div>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
                <ProgressBar value={o.eps_strength || 0} label="EPS Strength" color={o.eps_strength<30?"#ff4455":"#00ff88"}/>
                <ProgressBar value={o.price_strength || 0} label="Price Strength" color={o.price_strength<30?"#ff4455":"#00c8ff"}/>
                <ProgressBar value={o.buyer_demand_score || 0} label="Buyer Demand" color="#00c8ff"/>
                <ProgressBar value={o.group_rank || 0} label="Group Rank" color={o.group_rank>70?"#ff4455":"#00ff88"}/>
              </div>
            </div>
          </div>

          <div className="card fade-in">
            <div style={{padding:"10px 16px",borderBottom:"1px solid var(--border-dim)",fontSize:11,fontWeight:700,fontFamily:"var(--font-mono)",color:"var(--text-muted)",letterSpacing:1}}>GURU STRATEGY RATINGS</div>
            <div style={{padding:12}}>
              {d.guru_ratings.map((g,i) => (
                <div key={i} style={{padding:"8px 0",borderBottom:i<d.guru_ratings.length-1?"1px solid var(--border-dim)":"none"}}>
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:4}}>
                    <span style={{fontSize:12,fontWeight:700,color:"var(--text-primary)"}}>{g.guru}</span>
                    <span className={`badge ${g.score==="PASS"?"badge-pass":g.score==="FAIR"?"badge-fair":"badge-fail"}`}>
                      {g.score} {g.score_pct}%
                    </span>
                  </div>
                  <div style={{display:"flex",gap:4,flexWrap:"wrap"}}>
                    {(g.details || []).map((c,j) => (
                      <span key={j} style={{fontSize:8,padding:"1px 5px",borderRadius:2,fontFamily:"var(--font-mono)",
                        background:c.passed?"rgba(0,255,136,0.06)":"rgba(255,68,85,0.06)",
                        color:c.passed?"#00ff88":"#ff4455"}}>
                        {c.passed?"✓":"✗"} {c.detail}
                      </span>
                    ))}
                  </div>
                </div>
              ))}
              {d.guru_ratings.length === 0 && <div style={{color:"var(--text-muted)",fontSize:11,textAlign:"center",padding:20}}>No guru ratings available</div>}
            </div>
          </div>
        </div>

        {/* QUARTERLY + OWNERSHIP */}
        <div style={{display:"grid",gridTemplateColumns:"2fr 1fr",gap:16,marginBottom:16}}>
          <div className="card fade-in">
            <div style={{padding:"10px 16px",borderBottom:"1px solid var(--border-dim)",fontSize:11,fontWeight:700,fontFamily:"var(--font-mono)",color:"var(--text-muted)",letterSpacing:1}}>📊 FUNDAMENTAL SCORECARDS</div>
            <div style={{overflowX:"auto"}}>
              {screenerLoading ? (
                <div style={{padding:20,textAlign:"center",color:"var(--text-muted)",fontSize:11}}>Loading quarterly data...</div>
              ) : screenerData?.quarters?.length ? (
                <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                  <thead>
                    <tr style={{background:"rgba(0,255,136,0.03)"}}>
                      {["FQ","EPS","YOY","QOQ","SALES","YOY","QOQ","OPM%","P/E"].map((h,i)=>(
                        <th key={i} style={{padding:"6px 8px",textAlign:i===0?"left":"right",color:"var(--text-muted)",fontSize:9,fontFamily:"var(--font-mono)",fontWeight:700,borderBottom:"1px solid var(--border-dim)"}}>{h}</th>
                      ))}
                    </tr>
                  </thead>
                  <tbody>
                    {screenerData.quarters.slice(0,8).map((q,i) => (
                      <tr key={i} style={{borderBottom:"1px solid var(--border-dim)"}}>
                        <td style={{padding:"6px 8px",fontWeight:600,fontSize:11,color:"var(--text-primary)",fontFamily:"var(--font-mono)"}}>{q.label}</td>
                        <td style={{padding:"6px 8px",textAlign:"right",fontFamily:"var(--font-mono)"}}>{q.eps?.toFixed(1)}</td>
                        <td style={{padding:"6px 8px",textAlign:"right"}}><PctVal str={q.epsYoY != null ? (q.epsYoY > 0 ? "+" : "") + q.epsYoY.toFixed(1) + "%" : "—"}/></td>
                        <td style={{padding:"6px 8px",textAlign:"right"}}><PctVal str={q.epsQoQ != null ? (q.epsQoQ > 0 ? "+" : "") + q.epsQoQ.toFixed(1) + "%" : "—"}/></td>
                        <td style={{padding:"6px 8px",textAlign:"right",fontFamily:"var(--font-mono)"}}>{q.sales?.toLocaleString()}</td>
                        <td style={{padding:"6px 8px",textAlign:"right"}}><PctVal str={q.salesYoY != null ? (q.salesYoY > 0 ? "+" : "") + q.salesYoY.toFixed(1) + "%" : "—"}/></td>
                        <td style={{padding:"6px 8px",textAlign:"right"}}><PctVal str={q.salesQoQ != null ? (q.salesQoQ > 0 ? "+" : "") + q.salesQoQ.toFixed(1) + "%" : "—"}/></td>
                        <td style={{padding:"6px 8px",textAlign:"right",fontFamily:"var(--font-mono)"}}>{q.opm != null ? q.opm + "%" : "—"}</td>
                        <td style={{padding:"6px 8px",textAlign:"right",fontFamily:"var(--font-mono)",color:"var(--accent2)"}}>{screenerData.info?.pe || "—"}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              ) : (
                <div style={{padding:20,textAlign:"center",color:"var(--text-muted)",fontSize:11}}>No quarterly data available</div>
              )}
            </div>
          </div>

          <div className="card fade-in">
            <div style={{padding:"10px 16px",borderBottom:"1px solid var(--border-dim)",fontSize:11,fontWeight:700,fontFamily:"var(--font-mono)",color:"var(--text-muted)",letterSpacing:1}}>OWNERSHIP PATTERN</div>
            <div style={{padding:12}}>
              {d.ownership.promoter?.length > 0 ? (
                <OwnershipBar ownership={d.ownership}/>
              ) : (
                <div style={{color:"var(--text-muted)",fontSize:11,textAlign:"center",padding:20}}>Ownership data not available</div>
              )}
            </div>
          </div>
        </div>

        {/* SURVEILLANCE */}
        <div className="card fade-in" style={{marginBottom:16}}>
          <div style={{padding:"10px 16px",borderBottom:"1px solid var(--border-dim)",display:"flex",justifyContent:"space-between"}}>
            <span style={{fontSize:11,fontWeight:700,fontFamily:"var(--font-mono)",color:"var(--text-muted)",letterSpacing:1}}>🛡 SURVEILLANCE CHECKLIST</span>
            <div style={{textAlign:"right"}}>
              <div style={{fontSize:13,fontWeight:700,color:d.surveillance.red_flag_count===0?"#00ff88":"#ffaa00"}}>
                {d.surveillance.red_flag_count === 0 ? "No Red Flags" : `${d.surveillance.red_flag_count} Caution Flag(s)`}
              </div>
              <div style={{fontSize:9,color:"var(--text-muted)"}}>{d.surveillance.assessment_detail || "No obvious concerns with the stock. However, make sure you do the required fundamental & technical analysis before investing."}</div>
            </div>
          </div>
          <div style={{padding:12,display:"grid",gridTemplateColumns:"1fr",gap:2}}>
            {d.surveillance.flags.map((f,i) => (
              <div key={i} style={{display:"flex",alignItems:"center",justifyContent:"space-between",
                padding:"6px 10px",borderRadius:4,background:f.flagged?"rgba(255,68,85,0.04)":"transparent"}}>
                <span style={{fontSize:11,color:f.flagged?"#ff4455":"var(--text-secondary)"}}>{f.name}</span>
                <span style={{fontSize:16}}>{f.flagged?"🚩":"🟢"}</span>
              </div>
            ))}
            {d.surveillance.flags.length === 0 && <div style={{color:"var(--text-muted)",fontSize:11,textAlign:"center",padding:20}}>Surveillance data not available</div>}
          </div>
        </div>

        {/* Footer */}
        <div style={{padding:"12px 0",borderTop:"1px solid var(--border-dim)",display:"flex",justifyContent:"space-between",
          fontSize:9,color:"var(--text-muted)",fontFamily:"var(--font-mono)",letterSpacing:1}}>
          <span>TRADEDGE STOCK ANALYSIS • LIVE PRICE VIA YAHOO FINANCE</span>
          <a href="scanner.html" style={{color:"var(--accent)",textDecoration:"none"}}>← BACK TO SCANNER</a>
        </div>
      </div>
    </div>
  );
};

ReactDOM.createRoot(document.getElementById("root")).render(<StockPage/>);
</script>
</body>
</html>
